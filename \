#include <assert.h>
#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#define BUFFER_LEN 1024
#define SIZE_START 1024
enum TokenType {
  Identifier,
  T_eof,
  Assign,
  Plus,
  Minus,
  DRegister,
  ARegister,
  Memory,
  And,
  Or,
  Not,
  Semicolon,
  TT_END
};

typedef struct Token {
  char *literal;
  enum TokenType type;
} Token;

typedef struct TokenArray {
  size_t size;
  Token *values;
  size_t pos;
} TokenArray;

void initArray(TokenArray *array) {
  array->size = SIZE_START;

  array->pos = 0;
  array->values = malloc(sizeof(Token) * SIZE_START);
}

void resize(TokenArray *array) {
  array->size *= 2;

  Token *newBuffer = malloc(sizeof(Token) * array->size);
  for (int i = 0; i < array->pos; i++) {

    newBuffer[i] = array->values[i];
  }
  free(array->values);
  array->values = newBuffer;
}

void addElement(Token value, TokenArray *array) {
  if (array->pos == array->size) {
    resize(array);
  } else {
    array->values[array->pos++] = value;
  }
}

void printType(enum TokenType type) { // tested
  assert(type < TT_END);

  const char *typeIds[] = {"Identifier", "T_eof",     "Assign", "Plus", "Minus",
                           "DRegister",  "ARegister", "Memory", "And",  "Or",
                           "Not",        "Semicolon"

  };

  printf("%s\n", typeIds[type]);
}

typedef struct Scanner {
  char buffer[BUFFER_LEN];
  char buffer2[BUFFER_LEN];
  char *currentBuffer;
  int current;

  int bufferLength;
  int bufferLength2;
} Scanner;

void intializeScanner(Scanner *scanner) {
  for (int i = 0; i < BUFFER_LEN; i++) {
    scanner->buffer[i] = 0;
    scanner->buffer2[i] = 0;
  }
  scanner->current = 0;
  scanner->bufferLength = 0;
  scanner->currentBuffer = scanner->buffer;
}

void fillBuffer(Scanner *scanner, FILE *f) {
  size_t total = fread(scanner->buffer, sizeof(char), BUFFER_LEN, f);

  scanner->bufferLength = total;
  assert(scanner->bufferLength != 0);
}

char advance(Scanner *scanner) {
  scanner->current++;

  if (scanner->current >= BUFFER_LEN) {
    scanner->currentBuffer = scanner->buffer2;
    scanner->current = 0;
  }
  return scanner->currentBuffer[scanner->current];
}

int isAtEnd(Scanner *scanner) {
  return scanner->current == scanner->bufferLength &&
         scanner->bufferLength2 == 0;
}

